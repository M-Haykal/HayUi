---
import Layout from '../../layouts/Layout.astro';
import { Breeze as BreezeComponent } from '../../../../src/components/Breeze/Breeze';
---

<Layout title="Breeze (Card)">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-neutral-900 mb-2">Breeze</h1>
    <p class="text-neutral-600">A flexible container for content or data.</p>
  </div>

  <section class="space-y-12">
    <div>
      <h2 class="text-xl font-bold text-neutral-900 mb-4">Examples</h2>
      <div class="p-8 bg-neutral-50 border border-neutral-200 rounded-xl flex justify-center">
        <div class="bg-white border border-neutral-200 rounded-xl p-6 shadow-md max-w-sm hover:shadow-lg transition-shadow">
          <h3 class="font-bold text-lg mb-2">Card Title</h3>
          <p class="text-neutral-500 text-sm">This is a description inside the Breeze card component. It supports various padding and shadow options.</p>
          <button class="mt-4 px-3 py-1.5 bg-blue-400 text-white text-xs rounded-md">Action</button>
        </div>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-bold text-neutral-900 mb-4">Usage</h2>
      <div class="bg-neutral-900 rounded-lg p-6">
        <pre class="text-neutral-400"><code><BreezeComponent shadow="md">
  <h3>Content goes here</h3>
  <p>This card has a medium shadow.</p>
</BreezeComponent></code></pre>
      </div>
    </div>
  </section>
</Layout>
