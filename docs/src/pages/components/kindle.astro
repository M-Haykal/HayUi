  ---
import Layout from "../../layouts/Layout.astro";
import Showcase from "../../components/Showcase.astro";
import { Kindle as KindleComponent } from "../../../../src/components/Kindle/Kindle";
import { Typography } from "../../../../src/components/Typography/Typography";
---

<Layout title="Kindle (Checkbox & Radio)">
  <div class="mb-12">
    <Typography as="h1" variant="display-2" weight="bold" className="mb-4">Kindle</Typography>
    <Typography variant="body-large" color="muted">
      Checkbox dan Radio button component dengan animasi transisi scale yang smooth dan desain modern.
    </Typography>
  </div>

  <section class="space-y-16">
    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Checkbox</h2>
      <Showcase title="Default Checkbox" isExample={true}>
        <div class="flex flex-col gap-4 w-full max-w-sm">
          <KindleComponent client:load label="Default Checkbox" />
          <KindleComponent client:load label="Checked by default" defaultChecked />
          <KindleComponent client:load label="Disabled Checkbox" disabled />
          <KindleComponent client:load label="Disabled Checked" disabled defaultChecked />
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">With Description</h2>
      <Showcase title="Checkbox with description" isExample={true}>
        <div class="flex flex-col gap-4 w-full max-w-md">
          <KindleComponent 
            client:load
            label="Enable notifications"
            description="Kamu akan menerima update terbaru melalui email"
          />
          <KindleComponent 
            client:load
            label="Remember me"
            description="Simpan session login selama 30 hari"
            defaultChecked
          />
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Radio Buttons</h2>
      <Showcase title="Radio Button Group" isExample={true}>
        <div class="flex flex-col gap-4 w-full max-w-sm">
          <KindleComponent client:load type="radio" name="plan" label="Free Plan" />
          <KindleComponent client:load type="radio" name="plan" label="Pro Plan" defaultChecked />
          <KindleComponent client:load type="radio" name="plan" label="Enterprise Plan" />
          <KindleComponent client:load type="radio" name="plan" label="Disabled Option" disabled />
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Usage Example</h2>
      <Showcase title="Code Implementation">
        <pre><code>{`import { Kindle } from 'hayui';

// Checkbox
const CheckboxExample = () => {
  return (
    <Kindle
      label="Accept Terms & Conditions"
      description="Dengan mencentang kamu menyetujui syarat dan ketentuan"
      defaultChecked
      onChange={(e) => console.log(e.target.checked)}
    />
  );
};

// Radio Button
const RadioExample = () => {
  return (
    <div>
      <Kindle type="radio" name="plan" label="Free" value="free" />
      <Kindle type="radio" name="plan" label="Pro" value="pro" defaultChecked />
    </div>
  );
};`}</code></pre>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Animation Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="p-4 border rounded-lg">
          <h3 class="font-bold mb-2">✅ Scale Animation</h3>
          <p class="text-sm text-neutral-600">Icon check dan radio muncul dengan animasi scale 0 → 100%</p>
        </div>
        <div class="p-4 border rounded-lg">
          <h3 class="font-bold mb-2">✅ Smooth Transition</h3>
          <p class="text-sm text-neutral-600">Semua state berubah dengan durasi 200ms yang natural</p>
        </div>
        <div class="p-4 border rounded-lg">
          <h3 class="font-bold mb-2">✅ Focus Ring</h3>
          <p class="text-sm text-neutral-600">Ada ring focus untuk accessibility keyboard navigation</p>
        </div>
      </div>
    </div>
  </section>
</Layout>