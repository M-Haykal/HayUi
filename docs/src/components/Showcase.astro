---
interface Props {
  title: string;
  description?: string;
  isExample?: boolean;
}

const { title, description, isExample = false } = Astro.props;
---

<div class={`group relative mb-12 ${isExample ? 'bg-white rounded-3xl border border-neutral-100 shadow-xl overflow-hidden' : ''}`}>
  {!isExample && (
    <div class="mb-6">
      <h2 class="text-2xl font-bold text-neutral-900 tracking-tight">{title}</h2>
      {description && <p class="text-neutral-500 mt-2">{description}</p>}
    </div>
  )}

  {isExample && (
    <div class="px-8 py-4 border-b border-neutral-50 bg-neutral-50/50 flex items-center justify-between">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">{title}</h3>
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-red-400/20"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-400/20"></div>
        <div class="w-3 h-3 rounded-full bg-green-400/20"></div>
      </div>
    </div>
  )}

  <div class={`relative ${isExample ? 'p-12 min-h-[400px] flex items-center justify-center' : 'bg-neutral-950 rounded-2xl p-6 shadow-2xl relative overflow-hidden'}`}>
     {isExample ? (
       <div class="w-full h-full flex items-center justify-center">
         <slot />
       </div>
     ) : (
       <div class="font-mono text-sm overflow-x-auto text-blue-300">
         <div class="absolute top-0 right-0 p-4">
            <span class="text-[10px] uppercase font-bold text-neutral-600 bg-neutral-800 px-2 py-0.5 rounded">Code</span>
         </div>
         <slot />
       </div>
     )}
  </div>
</div>
