---
import Layout from "../../layouts/Layout.astro";
import Showcase from "../../components/Showcase.astro";
import { Lumina as LuminaComponent } from "../../../../src/components/Lumina/Lumina";
import { Typography } from "../../../../src/components/Typography/Typography";
---

<Layout title="Lumina (Tooltip)">
  <div class="mb-12">
    <Typography as="h1" variant="display-2" weight="bold" className="mb-4">Lumina</Typography>
    <Typography variant="body-large" color="muted">
      Tooltip component dengan animasi fade-in dan support berbagai posisi penempatan.
    </Typography>
  </div>

  <section class="space-y-16">
    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Basic Tooltip</h2>
      <Showcase title="Default Lumina" isExample={true}>
        <div class="flex justify-center items-center py-12">
          <LuminaComponent client:load content="Ini adalah tooltip">
            <span class="px-4 py-2 bg-blue-500 text-white rounded-lg cursor-pointer">Hover Disini</span>
          </LuminaComponent>
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">All Positions</h2>
      <Showcase title="Available Positions" isExample={true}>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-12">
          <LuminaComponent client:load position="top" content="Position Top">
            <span class="px-4 py-2 border border-neutral-300 rounded-lg cursor-pointer block text-center">Top</span>
          </LuminaComponent>
          
          <LuminaComponent client:load position="bottom" content="Position Bottom">
            <span class="px-4 py-2 border border-neutral-300 rounded-lg cursor-pointer block text-center">Bottom</span>
          </LuminaComponent>
          
          <LuminaComponent client:load position="left" content="Position Left">
            <span class="px-4 py-2 border border-neutral-300 rounded-lg cursor-pointer block text-center">Left</span>
          </LuminaComponent>
          
          <LuminaComponent client:load position="right" content="Position Right">
            <span class="px-4 py-2 border border-neutral-300 rounded-lg cursor-pointer block text-center">Right</span>
          </LuminaComponent>
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Usage Example</h2>
      <Showcase title="Code Implementation">
        <pre><code>{`import { Lumina } from 'hayui';

const Example = () => {
  return (
    <Lumina
      content="Salin ke clipboard"
      position="top"
    >
      <button>Copy</button>
    </Lumina>
  );
};`}</code></pre>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="p-4 border rounded-lg">
          <h3 class="font-bold mb-2">✅ Fade Animation</h3>
          <p class="text-sm text-neutral-600">Tooltip muncul dengan animasi fade-in smooth 200ms</p>
        </div>
        <div class="p-4 border rounded-lg">
          <h3 class="font-bold mb-2">✅ 4 Positions</h3>
          <p class="text-sm text-neutral-600">Support posisi top, bottom, left dan right</p>
        </div>
        <div class="p-4 border rounded-lg">
          <h3 class="font-bold mb-2">✅ Arrow Pointer</h3>
          <p class="text-sm text-neutral-600">Ada panah penunjuk yang menyesuaikan posisi</p>
        </div>
        <div class="p-4 border rounded-lg">
          <h3 class="font-bold mb-2">✅ Hover Trigger</h3>
          <p class="text-sm text-neutral-600">Muncul ketika hover dan hilang ketika mouse leave</p>
        </div>
      </div>
    </div>
  </section>
</Layout>