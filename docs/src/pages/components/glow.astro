---
import Layout from "../../layouts/Layout.astro";
import { Glow as GlowComponent } from "../../../../src/components/Glow/Glow";
---

<Layout title="Glow (Input)">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-neutral-900 mb-2">Glow</h1>
    <p class="text-neutral-600">
      A clean and functional input component with various states.
    </p>
  </div>

  <section class="space-y-12">
    <div>
      <h2 class="text-xl font-bold text-neutral-900 mb-4">Examples</h2>
      <div
        class="p-8 bg-white border border-neutral-200 rounded-xl max-w-md space-y-6">
        <div>
          <label class="block text-sm font-medium text-neutral-700 mb-2"
            >Label</label
          >
          <input
            type="text"
            placeholder="Simple input..."
            class="w-full px-4 py-2 rounded-lg border border-neutral-200 focus:ring-2 focus:ring-blue-400 outline-none transition-all"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-neutral-700 mb-2"
            >Error State</label
          >
          <input
            type="text"
            value="Invalid input"
            class="w-full px-4 py-2 rounded-lg border border-red-400 focus:ring-2 focus:ring-red-400 outline-none"
          />
          <p class="text-xs text-red-500 mt-1">This field is required.</p>
        </div>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-bold text-neutral-900 mb-4">Usage</h2>
      <div class="bg-neutral-900 rounded-lg p-6">
        <pre
          class="text-neutral-400"><GlowComponent label="Email Address" placeholder="Enter your email" helperText="We'll never share your email." /></pre>
      </div>
    </div>
  </section>
</Layout>
