---
import Layout from "../../layouts/Layout.astro";
import Showcase from "../../components/Showcase.astro";
import { Typography as TypographyComponent } from "../../../../src/components/Typography/Typography";
---

<Layout title="Typography">
  <div class="mb-12">
    <TypographyComponent as="h1" variant="display-2" weight="bold" className="mb-4">Typography</TypographyComponent>
    <TypographyComponent variant="body-large" color="muted">
      A comprehensive set of typographic styles for consistent communication.
    </TypographyComponent>
  </div>

  <section class="space-y-16">
    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Display Variants</h2>
      <Showcase title="Preview" isExample={true}>
        <div class="space-y-8 w-full max-w-2xl">
          <TypographyComponent variant="display-1">Display 1</TypographyComponent>
          <TypographyComponent variant="display-2">Display 2</TypographyComponent>
          <TypographyComponent variant="h1">Heading 1</TypographyComponent>
          <TypographyComponent variant="h2">Heading 2</TypographyComponent>
          <TypographyComponent variant="h3">Heading 3</TypographyComponent>
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Body Variants</h2>
      <Showcase title="Preview" isExample={true}>
        <div class="space-y-6 w-full max-w-2xl">
          <div>
            <TypographyComponent variant="caption" color="muted" className="mb-2">Body Large</TypographyComponent>
            <TypographyComponent variant="body-large">The quick brown fox jumps over the lazy dog. This is our large body text for long-form reading experience.</TypographyComponent>
          </div>
          <div>
            <TypographyComponent variant="caption" color="muted" className="mb-2">Body Base</TypographyComponent>
            <TypographyComponent variant="body-base">The quick brown fox jumps over the lazy dog. Our standard body text used across the entire application interface.</TypographyComponent>
          </div>
          <div>
            <TypographyComponent variant="caption" color="muted" className="mb-2">Body Small</TypographyComponent>
            <TypographyComponent variant="body-small">The quick brown fox jumps over the lazy dog. Small text for metadata, labels, and secondary information.</TypographyComponent>
          </div>
          <div>
            <TypographyComponent variant="caption" color="muted" className="mb-2">Caption</TypographyComponent>
            <TypographyComponent variant="caption">The quick brown fox jumps over the lazy dog.</TypographyComponent>
          </div>
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Colors</h2>
      <Showcase title="Preview" isExample={true}>
        <div class="grid grid-cols-2 gap-8 w-full max-w-2xl">
           <div class="flex flex-col gap-2">
             <TypographyComponent variant="body-base" color="default">Default Text</TypographyComponent>
             <TypographyComponent variant="body-base" color="muted">Muted Text</TypographyComponent>
           </div>
           <div class="flex flex-col gap-2">
             <TypographyComponent variant="body-base" color="primary">Primary Color</TypographyComponent>
             <TypographyComponent variant="body-base" color="secondary">Secondary Color</TypographyComponent>
             <TypographyComponent variant="body-base" color="danger">Danger Color</TypographyComponent>
           </div>
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Usage</h2>
      <Showcase title="Implementation">
        <pre><code>{`import { TypographyComponent } from 'hayui';

const Example = () => (
  <div className="space-y-4">
    <TypographyComponent as="h1" variant="display-1" weight="bold">
      Build beautiful interfaces
    </TypographyComponent>
    <TypographyComponent variant="body-large" color="muted">
      A foundational design system for modern web applications.
    </TypographyComponent>
  </div>
);`}</code></pre>
      </Showcase>
    </div>
  </section>
</Layout>
