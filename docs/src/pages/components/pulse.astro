---
import Layout from "../../layouts/Layout.astro";
import Showcase from "../../components/Showcase.astro";
import { Pulse } from "../../../../src/components/Pulse/Pulse";
import { Typography } from "../../../../src/components/Typography/Typography";
---

<Layout title="Pulse (Switch)">
  <div class="mb-12">
    <Typography as="h1" variant="display-2" weight="bold" className="mb-4">Pulse</Typography>
    <Typography variant="body-large" color="muted">
      A smooth toggle control for binary choices and settings.
    </Typography>
  </div>

  <section class="space-y-16">
    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Interactive Toggle</h2>
      <Showcase title="Switch Preview" isExample={true}>
        <div class="flex flex-col gap-8 items-center bg-white p-12 rounded-3xl border border-neutral-100 shadow-sm">
           <Pulse client:load label="Dark Mode" />
           <Pulse client:load label="Enable Notifications" checked={true} />
           <Pulse client:load label="Public Profile" size="sm" />
           <Pulse client:load label="Enterprise Mode" size="lg" />
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Usage</h2>
      <Showcase title="Implementation">
        <pre><code>{`import { Pulse } from 'hayui';
import { useState } from 'react';

const MySettings = () => {
  const [active, setActive] = useState(false);
  
  return (
    <Pulse 
      label="Auto-save" 
      checked={active} 
      onChange={(e) => setActive(e.target.checked)} 
    />
  );
}`}</code></pre>
      </Showcase>
    </div>
  </section>
</Layout>
