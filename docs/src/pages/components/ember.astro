---
import Layout from "../../layouts/Layout.astro";
import Showcase from "../../components/Showcase.astro";
import { Ember as EmberComponent } from "../../../../src/components/Ember/Ember";
import { Typography } from "../../../../src/components/Typography/Typography";
import { DummyProject } from "../../components/examples/DummyProject";
---

<Layout title="Ember (Button)">
  <div class="mb-12">
    <Typography as="h1" variant="display-2" weight="bold" className="mb-4">Ember</Typography>
    <Typography variant="body-large" color="muted">
      The workhorse of interaction. Buttons trigger actions, navigation, and changes in state.
    </Typography>
  </div>

  <section class="space-y-16">
    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Visual Variants</h2>
      <Showcase title="Styles Preview" isExample={true}>
        <div class="flex flex-wrap gap-6 items-center justify-center">
          <div class="flex flex-col items-center gap-2">
            <EmberComponent variant="primary">Primary</EmberComponent>
            <Typography variant="caption" color="muted">Default</Typography>
          </div>
          <div class="flex flex-col items-center gap-2">
            <EmberComponent variant="secondary">Secondary</EmberComponent>
            <Typography variant="caption" color="muted">Neutral</Typography>
          </div>
          <div class="flex flex-col items-center gap-2">
            <EmberComponent variant="danger">Danger</EmberComponent>
            <Typography variant="caption" color="muted">Destructive</Typography>
          </div>
          <div class="flex flex-col items-center gap-2">
            <EmberComponent variant="ghost">Ghost</EmberComponent>
            <Typography variant="caption" color="muted">Subtle</Typography>
          </div>
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">States & Sizes</h2>
      <Showcase title="Interactions Preview" isExample={true}>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 w-full max-w-2xl px-8">
           <div class="space-y-6">
              <Typography variant="h4" weight="semibold">Loading State</Typography>
              <EmberComponent variant="primary" isLoading={true} fullWidth={true}>Saving...</EmberComponent>
              <EmberComponent variant="secondary" isLoading={true} fullWidth={true}>Processing</EmberComponent>
           </div>
           <div class="space-y-6">
              <Typography variant="h4" weight="semibold">Sizes</Typography>
              <div class="flex flex-wrap items-end gap-3">
                 <EmberComponent variant="primary" size="xs">XS</EmberComponent>
                 <EmberComponent variant="primary" size="sm">Small</EmberComponent>
                 <EmberComponent variant="primary" size="md">Medium</EmberComponent>
                 <EmberComponent variant="primary" size="lg">Large</EmberComponent>
              </div>
           </div>
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Dummy Project Showcase</h2>
      <Typography variant="body-base" color="muted" className="mb-8">
        See how components work together in a real-world scenario.
      </Typography>
      <DummyProject client:load />
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Usage</h2>
      <Showcase title="Implementation">
        <pre><code>{`import { Ember } from 'hayui';

// Primary Button
<Ember variant="primary">Continue</Ember>

// Loading Button
<Ember isLoading={true} variant="secondary">
  Uploading
</Ember>

// Full Width
<Ember fullWidth={true} size="lg">
  Sign In
</Ember>`}</code></pre>
      </Showcase>
    </div>
  </section>
</Layout>
