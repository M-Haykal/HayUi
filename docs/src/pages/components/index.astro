---
import Layout from "../../layouts/Layout.astro";
import { Typography } from "../../../../src/components/Typography/Typography";
import { Ember } from "../../../../src/components/Ember/Ember";
---

<Layout title="Components Overview">
  <div class="py-12 md:py-20 text-center max-w-3xl mx-auto space-y-6">
    <Typography as="h1" variant="display-1" weight="bold">
      Interface <span class="bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent">Excellence</span>
    </Typography>
    <Typography variant="body-large" color="muted">
      A collection of high-performance, accessible, and stunning React components built for the next generation of web applications.
    </Typography>
    <div class="flex items-center justify-center gap-4 pt-4">
      <Ember variant="primary" size="lg">Get Started</Ember>
      <Ember variant="secondary" size="lg">GitHub</Ember>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12 pb-20">
    {[
      { name: 'Typography', desc: 'The foundation of clarity and communication.', path: '/components/typography' },
      { name: 'Ember (Button)', desc: 'Versatile buttons for every interaction.', path: '/components/ember' },
      { name: 'Iris (Modal)', desc: 'Elegant dialogs for focused user tasks.', path: '/components/iris' },
      { name: 'Badge', desc: 'Compact indicators for status and metadata.', path: '/components/badge' },
      { name: 'Flame (Alert)', desc: 'Critical communication and feedback.', path: '/components/flame' },
      { name: 'Pulse (Switch)', desc: 'Smooth binary controls for settings.', path: '/components/pulse' },
    ].map(comp => (
      <a href={comp.path} class="group p-8 rounded-[2rem] bg-white border border-neutral-100 shadow-sm hover:shadow-xl hover:border-blue-100 transition-all">
        <Typography variant="h3" weight="bold" className="mb-2 group-hover:text-blue-500 transition-colors">{comp.name}</Typography>
        <Typography variant="body-small" color="muted">{comp.desc}</Typography>
      </a>
    ))}
  </div>
</Layout>
