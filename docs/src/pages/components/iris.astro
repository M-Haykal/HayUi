---
import Layout from "../../layouts/Layout.astro";
import Showcase from "../../components/Showcase.astro";
import { IrisExample } from "../../components/examples/IrisExample";
import { Typography } from "../../../../src/components/Typography/Typography";

const usageCode = `import { Iris, Ember } from 'hayui';
import { useState } from 'react';

const MyComponent = () => {
  const [isOpen, setIsOpen] = useState(false);

  return (
    <>
      <Ember onClick={() => setIsOpen(true)}>Open Modal</Ember>
      <Iris 
        isOpen={isOpen} 
        onClose={() => setIsOpen(false)} 
        title="Welcome"
      >
        <p>This is the modal content.</p>
      </Iris>
    </>
  );
}`;
---

<Layout title="Iris (Modal)">
  <div class="mb-12">
    <Typography as="h1" variant="display-2" weight="bold" className="mb-4">Iris</Typography>
    <Typography variant="body-large" color="muted">
      A sophisticated dialog window that captures focus while keeping users in context.
    </Typography>
  </div>

  <Showcase title="Interactive Preview" isExample={true}>
    <IrisExample client:load />
  </Showcase>

  <section class="space-y-12">
    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Usage</h2>
      <Showcase title="Basic Implementation">
        <pre><code>{usageCode}</code></pre>
      </Showcase>
    </div>

    <div>
       <h2 class="text-2xl font-bold text-neutral-900 mb-6">Props</h2>
       <div class="overflow-x-auto">
         <table class="w-full text-left border-collapse">
           <thead>
             <tr class="border-b border-neutral-200">
               <th class="py-4 font-semibold text-neutral-900">Prop</th>
               <th class="py-4 font-semibold text-neutral-900">Type</th>
               <th class="py-4 font-semibold text-neutral-900">Default</th>
               <th class="py-4 font-semibold text-neutral-900">Description</th>
             </tr>
           </thead>
           <tbody class="text-neutral-600">
             <tr class="border-b border-neutral-100">
               <td class="py-4 font-mono text-sm text-blue-500">isOpen</td>
               <td class="py-4 font-mono text-sm">boolean</td>
               <td class="py-4 font-mono text-sm">-</td>
               <td class="py-4">Controls the visibility of the modal.</td>
             </tr>
             <tr class="border-b border-neutral-100">
               <td class="py-4 font-mono text-sm text-blue-500">onClose</td>
               <td class="py-4 font-mono text-sm">() => void</td>
               <td class="py-4 font-mono text-sm">-</td>
               <td class="py-4">Function called when the modal is requested to close.</td>
             </tr>
             <tr class="border-b border-neutral-100">
               <td class="py-4 font-mono text-sm text-blue-500">title</td>
               <td class="py-4 font-mono text-sm">string</td>
               <td class="py-4 font-mono text-sm">-</td>
               <td class="py-4">The text displayed in the modal header.</td>
             </tr>
             <tr class="border-b border-neutral-100">
               <td class="py-4 font-mono text-sm text-blue-500">size</td>
               <td class="py-4 font-mono text-sm">'sm' | 'md' | 'lg' | 'xl' | 'full'</td>
               <td class="py-4 font-mono text-sm">'md'</td>
               <td class="py-4">The maximum width of the modal.</td>
             </tr>
           </tbody>
         </table>
       </div>
    </div>
  </section>
</Layout>
