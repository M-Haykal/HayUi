---
import Layout from "../../layouts/Layout.astro";
import Showcase from "../../components/Showcase.astro";
import { Badge as BadgeComponent } from "../../../../src/components/Badge/Badge";
import { StatusCard } from "../../components/examples/StatusCard";
import { Typography } from "../../../../src/components/Typography/Typography";
---

<Layout title="Badge">
  <div class="mb-12">
    <Typography as="h1" variant="display-2" weight="bold" className="mb-4">Badge</Typography>
    <Typography variant="body-large" color="muted">
      Small status indicators used to highlight important metadata or categorization.
    </Typography>
  </div>

  <section class="space-y-16">
    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Components in Context</h2>
      <Showcase title="Profile Status Showcase" isExample={true}>
        <StatusCard client:load />
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Variants</h2>
      <Showcase title="Default Preview" isExample={true}>
        <div class="flex flex-wrap gap-4 items-center justify-center">
          <BadgeComponent variant="neutral">Neutral</BadgeComponent>
          <BadgeComponent variant="primary">Primary</BadgeComponent>
          <BadgeComponent variant="success">Success</BadgeComponent>
          <BadgeComponent variant="warning">Warning</BadgeComponent>
          <BadgeComponent variant="error">Error</BadgeComponent>
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">With Dot Indication</h2>
      <Showcase title="Status Preview" isExample={true}>
        <div class="flex flex-wrap gap-4 items-center justify-center">
          <BadgeComponent variant="neutral" dot={true}>Offline</BadgeComponent>
          <BadgeComponent variant="primary" dot={true}>In Progress</BadgeComponent>
          <BadgeComponent variant="success" dot={true}>Live Now</BadgeComponent>
          <BadgeComponent variant="warning" dot={true}>Away</BadgeComponent>
          <BadgeComponent variant="error" dot={true}>Issue Detected</BadgeComponent>
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Usage</h2>
      <Showcase title="Basic Implementation">
        <pre><code>{`import { Badge } from 'hayui';

const Example = () => (
  <Badge variant="success" dot={true}>
    Active
  </Badge>
);`}</code></pre>
      </Showcase>
    </div>
  </section>
</Layout>
