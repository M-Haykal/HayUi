---
const components = [
  { name: 'Ember (Button)', href: '/components/ember' },
  { name: 'Glow (Input)', href: '/components/glow' },
  { name: 'Flame (Alert)', href: '/components/flame' },
  { name: 'Breeze (Card)', href: '/components/breeze' },
  { name: 'Badge', href: '/components/badge' },
  { name: 'Harmony (Accordion)', href: '/components/harmony' },
  { name: 'Iris (Modal)', href: '/components/iris' },
  { name: 'Juniper (Breadcrumb)', href: '/components/juniper' },
  { name: 'Kindle (Checkbox)', href: '/components/kindle' },
  { name: 'Lumina (Tooltip)', href: '/components/lumina' },
  { name: 'Meadow (Select)', href: '/components/meadow' },
  { name: 'Orbit (Tabs)', href: '/components/orbit' },
  { name: 'Phantom (Skeleton)', href: '/components/phantom' },
  { name: 'Pulse (Switch)', href: '/components/pulse' },
  { name: 'River (Progress)', href: '/components/river' },
  { name: 'Summit (Avatar)', href: '/components/summit' },
  { name: 'Typography', href: '/components/typography' },
];
---

<aside class="w-64 bg-white border-r border-neutral-200 sticky top-0 h-screen overflow-y-auto hidden md:block">
  <div class="p-6">
    <a href="/" class="text-xl font-bold text-blue-500 tracking-tight">HayUi</a>
    <p class="text-xs text-neutral-400 mt-1">Component Library v1.0</p>
  </div>
  
  <nav class="px-4 pb-8">
    <div class="mb-4">
      <h3 class="px-2 text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Getting Started</h3>
      <a href="/" class="block px-2 py-1.5 text-sm text-neutral-600 hover:text-blue-500 rounded-md hover:bg-neutral-50 transition-colors">Introduction</a>
    </div>

    <div>
      <h3 class="px-2 text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Components</h3>
      <div class="space-y-1">
        {components.map((comp) => (
          <a
            href={comp.href}
            class="block px-2 py-1.5 text-sm text-neutral-600 hover:text-blue-500 rounded-md hover:bg-neutral-50 transition-colors"
          >
            {comp.name}
          </a>
        ))}
      </div>
    </div>
  </nav>
</aside>
