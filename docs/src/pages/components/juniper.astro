---
import Layout from "../../layouts/Layout.astro";
import Showcase from "../../components/Showcase.astro";
import { Juniper as JuniperComponent } from "../../../../src/components/Juniper/Juniper";
import { Typography } from "../../../../src/components/Typography/Typography";
---

<Layout title="Juniper (Breadcrumb)">
  <div class="mb-12">
    <Typography as="h1" variant="display-2" weight="bold" className="mb-4">Juniper</Typography>
    <Typography variant="body-large" color="muted">
      Breadcrumb navigation component untuk menampilkan hierarki lokasi user pada website.
    </Typography>
  </div>

  <section class="space-y-16">
    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Basic Usage</h2>
      <Showcase title="Default Breadcrumb" isExample={true}>
        <JuniperComponent
          items={[
            { label: "Home", href: "/" },
            { label: "Components", href: "/components" },
            { label: "Juniper" },
          ]}
        />
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">With Custom Separator</h2>
      <Showcase title="Custom Separator" isExample={true}>
        <div class="flex flex-col gap-6 items-center">
          <JuniperComponent
            separator="→"
            items={[
              { label: "Dashboard", href: "/" },
              { label: "Settings", href: "/settings" },
              { label: "Profile" },
            ]}
          />
          
          <JuniperComponent
            separator="›"
            items={[
              { label: "Products", href: "/" },
              { label: "Categories", href: "/categories" },
              { label: "Electronics", href: "/categories/electronics" },
              { label: "Laptop" },
            ]}
          />
        </div>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">With Icons</h2>
      <Showcase title="Icon Breadcrumb" isExample={true}>
        <JuniperComponent
          items={[
            { label: "Home", href: "/", icon: "🏠" },
            { label: "Documentation", href: "/docs", icon: "📚" },
            { label: "Components", icon: "🧩" },
          ]}
        />
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Usage Example</h2>
      <Showcase title="Code Implementation">
        <pre><code>{`import { Juniper } from 'hayui';

const Example = () => {
  return (
    <Juniper
      items={[
        { label: "Home", href: "/" },
        { label: "Components", href: "/components" },
        { label: "Juniper" },
      ]}
      separator="›"
    />
  );
}`}</code></pre>
      </Showcase>
    </div>

    <div>
      <h2 class="text-2xl font-bold text-neutral-900 mb-6">Props</h2>
      <Showcase title="Available Props">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b">
                <th class="text-left py-3 px-4">Prop</th>
                <th class="text-left py-3 px-4">Type</th>
                <th class="text-left py-3 px-4">Default</th>
                <th class="text-left py-3 px-4">Description</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b">
                <td class="py-3 px-4 font-mono font-medium">items</td>
                <td class="py-3 px-4 font-mono text-blue-600">JuniperItem[]</td>
                <td class="py-3 px-4 font-mono">required</td>
                <td class="py-3 px-4">Array item breadcrumb</td>
              </tr>
              <tr class="border-b">
                <td class="py-3 px-4 font-mono font-medium">separator</td>
                <td class="py-3 px-4 font-mono text-blue-600">ReactNode</td>
                <td class="py-3 px-4 font-mono">" / "</td>
                <td class="py-3 px-4">Custom separator antar item</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-mono font-medium">className</td>
                <td class="py-3 px-4 font-mono text-blue-600">string</td>
                <td class="py-3 px-4 font-mono">""</td>
                <td class="py-3 px-4">Additional CSS classes</td>
              </tr>
            </tbody>
          </table>
        </div>
      </Showcase>
    </div>
  </section>
</Layout>